# ─────────────────────────────────────────────────────────────
#  StreamPulse AI — Environment Variables
#  Copy to .env and fill in values before running
#  cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_DB=streampulse
POSTGRES_USER=spuser
POSTGRES_PASSWORD=sppassword

# PRODUCTION: Replace with Railway connection string
# DATABASE_URL=postgresql://user:pass@host:5432/streampulse

# ── Redis ─────────────────────────────────────────────────────
# Local: auto-configured from docker-compose
# PRODUCTION: Replace with Railway Redis URL
# REDIS_URL=redis://default:password@host:6379

# ── Gateway ───────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_in_production
CORS_ORIGIN=http://localhost:5173

# PRODUCTION (Vercel dashboard URL)
# CORS_ORIGIN=https://streampulse-ai.vercel.app

# ── ML Services ───────────────────────────────────────────────
# Local: auto-configured from docker-compose
# PRODUCTION: Replace with HuggingFace Spaces URLs
# ML_DROP_URL=https://your-username-streampulse-drop.hf.space
# ML_SENTIMENT_URL=https://your-username-streampulse-sentiment.hf.space

# ── Monitoring ────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin_change_in_prod

# ── Dashboard (Vite env vars — must prefix with VITE_) ────────
# These go in dashboard/.env (not here)
# VITE_GATEWAY_URL=https://streampulse-api.onrender.com
# VITE_ML_DROP_URL=https://your-username-streampulse-drop.hf.space
# VITE_ML_SENTIMENT_URL=https://your-username-streampulse-sentiment.hf.space
